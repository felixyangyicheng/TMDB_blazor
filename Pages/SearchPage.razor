@page "/search"
@using TMDB_blazor.Components
@using TMDB_blazor.Data
@using TMDbLib.Objects.Movies
@using TMDbLib.Objects.Search

<MudContainer Class="my-4 animate-in">

    @* Search header card *@
    <MudPaper Elevation="0" Class="pa-4 mb-4" Style="background:#111827;border:1px solid #1E293B;border-radius:10px;">
        <h5 style="color:#F1F5F9;font-weight:600;margin-bottom:12px;">Search Movies</h5>

        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
            <span style="color:#64748B;font-size:0.8rem;">Filters:</span>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       OnClick="e=>ChangeSearchLikedCondition()"
                       StartIcon="@Icons.Material.Rounded.Favorite">
                Favorites @(SearchLikedEnable ? "ON" : "OFF")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       OnClick="e=>ChangeSearchViewedCondition()"
                       StartIcon="@Icons.Material.Rounded.RemoveRedEye">
                Viewed @(SearchViewedEnable ? "ON" : "OFF")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       OnClick="e=>{SearchAdultEnable = !SearchAdultEnable; InvokeAsync(StateHasChanged);}"
                       StartIcon="@Icons.Material.Rounded.SafetyDivider">
                @(SearchAdultEnable ? "Adult OK" : "Children Only")
            </MudButton>
        </div>

        <div class="divider-gradient"></div>

        <SearchBarItem OnSearchChanged="InputChanged"></SearchBarItem>

        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                   OnClick="e=>OrderByReleaseDate()" StartIcon="@Icons.Material.Rounded.SwapVert">
            Sort by Date
        </MudButton>
    </MudPaper>

    @* Results *@
    @if (DisplayResult != null)
    {
        if (loading)
        {
            <div style="text-align:center;padding:40px;">
                <Fold Color="#14B8A6" />
                <p style="color:#94A3B8;margin-top:12px;">Searching...</p>
            </div>
        }
        else if (DisplayResult.Any())
        {
            <MudPaper Elevation="0" Class="pa-4" Style="background:#111827;border:1px solid #1E293B;border-radius:10px;">
                <h5 style="color:#F1F5F9;font-weight:600;margin-bottom:8px;">
                    Results <span style="color:#64748B;font-weight:400;">(@DisplayResult.Count)</span>
                </h5>
                <div class="divider-gradient"></div>
                <GenericList T="UserMovie" Items="DisplayResult" ItemsPerPage="10">
                    <TableHeader>
                        <tr>
                            <th>Title</th>
                            <th>Release</th>
                            <th>Rating</th>
                            <th>Viewed</th>
                            <th>Liked</th>
                            <th></th>
                        </tr>
                    </TableHeader>
                    <ItemTemplate Context="r">
                        <tr>
                            <td>
                                <span style="font-weight:600;">@r.Title</span>
                                @if (r.ReleaseDate is not null)
                                {
                                    <span style="color:#64748B;font-size:0.75rem;display:block;">@r.OriginalTitle</span>
                                }
                            </td>
                            <td>@r.ReleaseDate?.ToString("d")</td>
                            <td>
                                <span style="color:#F1F5F9;font-weight:600;">⭐ @r.VoteAverage.ToString("0.0")</span>
                            </td>
                            <td>
                                @if (r.Viewed == true)
                                {
                                    <MudIcon Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                }
                                else
                                {
                                    <MudIcon Color="Color.Default" Icon="@Icons.Material.Filled.RadioButtonUnchecked" Size="Size.Small" />
                                }
                            </td>
                            <td>
                                @if (r.Favorite == true)
                                {
                                    <MudIcon Color="Color.Warning" Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                                }
                                else
                                {
                                    <MudIcon Color="Color.Default" Icon="@Icons.Material.Filled.StarBorder" Size="Size.Small" />
                                }
                            </td>
                            <td>
                                <MudIconButton Icon="@Icons.Material.Rounded.OpenInNew"
                                               Color="Color.Primary" Size="Size.Small"
                                               OnClick="e=>Redirect(r)" />
                            </td>
                        </tr>
                    </ItemTemplate>
                    <TableFooter></TableFooter>
                </GenericList>
            </MudPaper>
        }
        else
        {
            <p style="text-align:center;color:#64748B;padding:40px;">No results yet. Start searching!</p>
        }
    }
</MudContainer>
