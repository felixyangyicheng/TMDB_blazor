@page "/moviepage/{identity:int}"

@if (Movie is not null)
{
    <MudContainer Class="my-4 animate-in">

        <div class="row" style="align-items:flex-start;">
            @* Left Column — Poster *@
            <div class="col-md-4" style="position:sticky;top:72px;">
                <div class="poster-border">
                    <MudImage Src="@GetCompletedPosterPath(Movie.PosterPath)" Alt="Movie poster"
                              Style="width:100%;display:block;" />
                </div>

                <div style="display:flex;gap:8px;margin-top:12px;">
                    @if (viewed.Any(a => a.Id == Movie!.Id))
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" Disabled="true"
                                   StartIcon="@Icons.Material.Rounded.CheckCircle" Style="flex:1;text-transform:none;">
                            Viewed
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Rounded.RemoveRedEye"
                                   OnClick="async e=> await AddViewed(Movie!)" Style="flex:1;text-transform:none;">
                            Mark Viewed
                        </MudButton>
                    }
                    @if (favorites.Any(a => a.Id == Movie!.Id))
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" Disabled="true"
                                   StartIcon="@Icons.Material.Rounded.Star" Style="flex:1;text-transform:none;">
                            Liked
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Rounded.FavoriteBorder"
                                   OnClick="async e=> await AddLiked(Movie!)" Style="flex:1;text-transform:none;">
                            Like
                        </MudButton>
                    }
                </div>
            </div>

            @* Right Column — Info Cards *@
            <div class="col-md-8">

                <MudPaper Elevation="0" Class="pa-4 mb-3" Style="background:#111827;border:1px solid #1E293B;border-radius:12px;">
                    <h2 style="margin:0;font-weight:700;color:#F1F5F9;letter-spacing:-0.3px;">
                        @Movie.Title
                        @if (Movie.ReleaseDate is not null)
                        { <span style="color:#64748B;font-weight:400;font-size:1.2rem;">(@Movie!.ReleaseDate.Value.Year)</span> }
                    </h2>
                    <div style="display:flex;gap:10px;margin-top:10px;align-items:center;flex-wrap:wrap;">
                        @if (Movie!.Adult == true)
                        { <span class="chip-red">+18</span> }
                        <span style="color:#F59E0B;font-weight:600;">⭐ @Movie.VoteAverage.ToString("0.0")</span>
                        <span style="color:#64748B;font-size:0.82rem;">@Movie.VoteCount.ToString("N0") votes</span>
                        <span style="color:#64748B;font-size:0.82rem;">🌐 @Movie.OriginalLanguage?.ToUpper()</span>
                        <span class="chip-teal">@($"{Movie.Popularity:N0}") views</span>
                    </div>
                </MudPaper>

                @if (!string.IsNullOrWhiteSpace(Movie.Overview))
                {
                    <MudPaper Elevation="0" Class="pa-4 mb-3" Style="background:#111827;border:1px solid #1E293B;border-radius:12px;">
                        <h5 style="color:#94A3B8;margin-bottom:8px;font-weight:600;text-transform:uppercase;font-size:0.72rem;letter-spacing:0.5px;">Synopsis</h5>
                        <p style="color:#CBD5E1;line-height:1.8;margin:0;">@Movie.Overview</p>
                        @if (!string.IsNullOrEmpty(MovieTrailerUrl))
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                       Href="@MovieTrailerUrl" Target="_blank"
                                       StartIcon="@Icons.Material.Rounded.PlayArrow" Class="mt-3" Style="text-transform:none;">
                                Watch Trailer
                            </MudButton>
                        }
                    </MudPaper>
                }

                <MudPaper Elevation="0" Class="pa-4 mb-3" Style="background:#111827;border:1px solid #1E293B;border-radius:12px;">
                    <h5 style="color:#94A3B8;margin-bottom:12px;font-weight:600;text-transform:uppercase;font-size:0.72rem;letter-spacing:0.5px;">Details</h5>
                    <MudGrid Spacing="3" Justify="Justify.FlexStart">
                        <MudItem xs="6" sm="3"><span style="color:#64748B;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;">ID</span><br/><span style="color:#F1F5F9;">@Movie.Id</span></MudItem>
                        <MudItem xs="6" sm="3"><span style="color:#64748B;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;">Budget</span><br/><span style="color:#F1F5F9;">@($"{Movie.Budget:N0}")</span></MudItem>
                        <MudItem xs="6" sm="3"><span style="color:#64748B;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;">Original</span><br/><span style="color:#F1F5F9;">@Movie.OriginalTitle</span></MudItem>
                        @if (Movie.Homepage is not null)
                        { <MudItem xs="6" sm="3"><span style="color:#64748B;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;">Site</span><br/><a href="@Movie.Homepage" target="_blank" style="color:#14B8A6;font-size:0.85rem;">🔗 Open</a></MudItem> }
                        @if (Movie.ImdbId is not null)
                        { <MudItem xs="6" sm="3"><span style="color:#64748B;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;">IMDb</span><br/><a href="https://www.imdb.com/title/@Movie.ImdbId" target="_blank" style="color:#14B8A6;font-size:0.85rem;">🎥 Page</a></MudItem> }
                    </MudGrid>
                </MudPaper>

                @if (Movie!.Genres is { Count: > 0 })
                {
                    <MudPaper Elevation="0" Class="pa-4 mb-3" Style="background:#111827;border:1px solid #1E293B;border-radius:12px;">
                        <h5 style="color:#94A3B8;margin-bottom:8px;font-weight:600;text-transform:uppercase;font-size:0.72rem;letter-spacing:0.5px;">Genres</h5>
                        <div style="display:flex;gap:6px;flex-wrap:wrap;">
                            @foreach (var g in Movie.Genres)
                            { <span class="chip-teal">@g.Name</span> }
                        </div>
                    </MudPaper>
                }

                @if (Movie!.ProductionCompanies is { Count: > 0 })
                {
                    <MudPaper Elevation="0" Class="pa-4 mb-3" Style="background:#111827;border:1px solid #1E293B;border-radius:12px;">
                        <h5 style="color:#94A3B8;margin-bottom:8px;font-weight:600;text-transform:uppercase;font-size:0.72rem;letter-spacing:0.5px;">Production</h5>
                        <div style="display:flex;gap:6px;flex-wrap:wrap;">
                            @foreach (var pc in Movie.ProductionCompanies)
                            { <span class="chip-indigo">@pc.Name</span> }
                        </div>
                    </MudPaper>
                }

                @if (Movie!.Reviews?.Results is { Count: > 0 })
                {
                    <MudPaper Elevation="0" Class="pa-4 mb-3" Style="background:#111827;border:1px solid #1E293B;border-radius:12px;">
                        <h5 style="color:#94A3B8;margin-bottom:12px;font-weight:600;text-transform:uppercase;font-size:0.72rem;letter-spacing:0.5px;">Reviews (@Movie.Reviews.Results.Count)</h5>
                        @foreach (var review in Movie.Reviews.Results)
                        {
                            <div style="border-left:2px solid #14B8A6;padding:4px 0 4px 14px;margin-bottom:14px;">
                                <strong style="color:#F1F5F9;font-size:0.9rem;">@review.Author</strong>
                                <p style="color:#94A3B8;margin:4px 0 0;font-size:0.84rem;line-height:1.6;">@review.Content</p>
                            </div>
                        }
                    </MudPaper>
                }
            </div>
        </div>
    </MudContainer>
}
