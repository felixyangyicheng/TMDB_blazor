<div style="background:#0F172A;border:1px solid #1E293B;border-radius:10px;padding:20px;">
    <h5 style="color:#F1F5F9;font-weight:600;margin-bottom:4px;">@SelectedItem?.Title</h5>
    @if (SelectedItem?.ReleaseDate is not null)
    {
        <span style="color:#64748B;font-size:0.8rem;">@SelectedItem!.ReleaseDate.Value.ToString("d")</span>
    }
    <div class="divider-gradient"></div>

    <MudGrid Spacing="1" Justify="Justify.FlexStart" Style="font-size:0.82rem;">
        <MudItem xs="6">
            <span style="color:#64748B;">Rating</span><br/>
            <span style="color:#F1F5F9;font-weight:600;">⭐ @(SelectedItem?.VoteAverage.ToString("0.0"))</span>
        </MudItem>
        <MudItem xs="6">
            <span style="color:#64748B;">Votes</span><br/>
            <span style="color:#F1F5F9;">@(SelectedItem?.VoteCount.ToString("N0"))</span>
        </MudItem>
        <MudItem xs="6">
            <span style="color:#64748B;">Popularity</span><br/>
            <span style="color:#F1F5F9;">@(SelectedItem?.Popularity.ToString("N0"))</span>
        </MudItem>
        <MudItem xs="6">
            <span style="color:#64748B;">Language</span><br/>
            <span style="color:#F1F5F9;">@SelectedItem?.OriginalLanguage?.ToUpper()</span>
        </MudItem>
    </MudGrid>

    <div style="margin-top:12px;">
        <p style="color:#94A3B8;font-size:0.82rem;line-height:1.6;max-height:100px;overflow-y:auto;">
            @SelectedItem?.Overview
        </p>
    </div>

    <div style="display:flex;gap:6px;margin-top:12px;">
        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="e=>AddToViewed(SelectedItem!)"
                   Style="flex:1;text-transform:none;font-size:0.78rem;">
            <MudIcon Icon="@Icons.Material.Rounded.RemoveRedEye" Size="Size.Small" Class="mr-1" /> Viewed
        </MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Secondary"
                   OnClick="e=>AddToFavorite(SelectedItem!)"
                   Style="flex:1;text-transform:none;font-size:0.78rem;">
            <MudIcon Icon="@Icons.Material.Rounded.Favorite" Size="Size.Small" Class="mr-1" /> Like
        </MudButton>
    </div>
</div>
