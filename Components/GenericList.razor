@typeparam T

<table class="modern-table" style="margin:0;width:100%;">
    <thead>
        @if (TableHeader is not null) { @TableHeader }
    </thead>
    <tbody>
        @foreach (var i in CurrentDisplay)
        {
            if (ItemTemplate is not null) { @ItemTemplate(i) }
        }
    </tbody>
    <tfoot>
        @if (TableFooter is not null) { @TableFooter }

        @if (TotalPages() > 1)
        {
            <tr>
                <td colspan="100" style="padding:12px 0;text-align:center;border-top:1px solid #1E293B;">
                    <div style="display:flex;justify-content:center;align-items:center;gap:2px;">
                        <MudIconButton Icon="@Icons.Material.Rounded.FirstPage"
                                       Size="Size.Small" Color="Color.Inherit"
                                       Disabled="CurrentPage == 1"
                                       OnClick="@MoveFirst" />
                        <MudIconButton Icon="@Icons.Material.Rounded.ChevronLeft"
                                       Size="Size.Small" Color="Color.Inherit"
                                       Disabled="CurrentPage == 1"
                                       OnClick="@MoveBack" />

                        <span style="display:inline-flex;align-items:center;gap:6px;background:#0F172A;border:1px solid #1E293B;border-radius:8px;padding:4px 14px;font-size:0.8rem;color:#CBD5E1;margin:0 4px;">
                            <span style="color:#14B8A6;font-weight:600;">@CurrentPage</span>
                            <span style="color:#64748B;">/</span>
                            <span style="color:#94A3B8;">@TotalPages()</span>
                        </span>

                        <MudIconButton Icon="@Icons.Material.Rounded.ChevronRight"
                                       Size="Size.Small" Color="Color.Inherit"
                                       Disabled="@AtLastPage()"
                                       OnClick="@MoveNext" />
                        <MudIconButton Icon="@Icons.Material.Rounded.LastPage"
                                       Size="Size.Small" Color="Color.Inherit"
                                       Disabled="@AtLastPage()"
                                       OnClick="@MoveLast" />
                    </div>
                </td>
            </tr>
        }
    </tfoot>
</table>
